      "name": "issues_list",
      "description": "List repository issues",
      "params": [
        {
          "name": "owner",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Path parameter owner"
        },
        {
          "name": "repo",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Path parameter repo"
        },
        {
          "name": "state",
          "in": "query",
          "type": "string",
          "required": false,
          "description": "Indicates the state of the issues to return."
        },
        {
          "name": "labels",
          "in": "query",
          "type": "string",
          "required": false,
          "description": "A comma-separated list of label names."
        },
        {
          "name": "sort",
          "in": "query",
          "type": "string",
          "required": false,
          "description": ""
        },
        {
          "name": "per_page",
          "in": "query",
          "type": "number",
          "required": false,
          "description": "The number of results per page (max 100)."
        },
        {
          "name": "page",
          "in": "query",
          "type": "number",
          "required": false,
          "description": ""
        }
      ],
      "requests": [
        {
          "key": "main",
          "method": "GET",
          "path": "/repos/{owner}/{repo}/issues"
        }
      ],
      "responseMap": [
        {
          "from": "id",
          "to": "id",
          "source": "main",
          "reason": "Stable identifier if present"
        }
      ]
    },
