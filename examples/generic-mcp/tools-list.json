{
  "jsonrpc": "2.0",
  "id": 1,
  "result": {
    "tools": [
      {
        "name": "search_docs",
        "description": "Use when: the user needs to find internal docs by keyword, title, owner, or path. Returns matching documents with short snippets and canonical URLs.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Keyword, title, owner, or path fragment to search for."
            }
          },
          "required": ["query"]
        }
      },
      {
        "name": "list_docs",
        "description": "List docs.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "space": {
              "type": "string"
            }
          }
        }
      },
      {
        "name": "get_doc",
        "description": "Use when: the user has a specific document id or URL and needs the full current document body plus metadata.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "docId": {
              "type": "string",
              "description": "Document id or canonical document URL."
            }
          },
          "required": ["docId"]
        }
      },
      {
        "name": "create_task",
        "description": "Create a task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "body": {
              "type": "string"
            }
          },
          "required": ["title"]
        }
      },
      {
        "name": "update_task",
        "description": "Use when: the user asks to change an existing task's title, body, assignee, due date, or status. Returns the updated task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "description": "Existing task id."
            },
            "fields": {
              "type": "object",
              "description": "Fields to update."
            }
          },
          "required": ["taskId", "fields"]
        }
      },
      {
        "name": "delete_task",
        "description": "Delete a task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": ["taskId"]
        }
      },
      {
        "name": "confirm_task_creation",
        "description": "Confirm a drafted task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "pendingId": {
              "type": "string"
            }
          },
          "required": ["pendingId"]
        }
      },
      {
        "name": "run_any_request",
        "description": "Run any request against the workspace API.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "method": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "body": {
              "type": "object"
            }
          },
          "required": ["method", "path"]
        }
      }
    ]
  }
}
