{
  "name": "mcplens-cli",
  "version": "0.1.2",
  "description": "Audit MCP tool activation locally and compile bloated APIs into lean, agent-optimized MCP servers",
  "license": "MIT",
  "author": "silvermango9927",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvermango9927/mcplens-cli.git"
  },
  "bugs": {
    "url": "https://github.com/silvermango9927/mcplens-cli/issues"
  },
  "homepage": "https://github.com/silvermango9927/mcplens-cli#readme",
  "keywords": [
    "mcplens",
    "mcp",
    "mcp-audit",
    "tool-activation",
    "agent",
    "openapi",
    "api",
    "codegen",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcplens": "dist/cli.js",
    "agentify": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/mapping/runtime.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "cli": "tsx src/cli.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test && node tests/scripts/pack-smoke.mjs",
    "smoke:pack": "npm run build && node tests/scripts/pack-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@apidevtools/swagger-parser": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
