{
  "agentifyVersion": 1,
  "api": {
    "name": "Trackly",
    "baseUrl": "https://api.trackly.example",
    "auth": { "type": "bearer", "envVar": "TRACKLY_API_TOKEN" }
  },
  "tools": [
    {
      "name": "get_issue",
      "description": "Fetch one issue",
      "params": [
        { "name": "id", "in": "path", "type": "string", "required": true, "description": "Issue id" }
      ],
      "requests": [
        { "key": "main", "method": "GET", "path": "/issues/{id}" }
      ],
      "responseMap": [
        { "from": "id", "to": "id", "source": "main", "reason": "Stable issue id" },
        { "from": "key", "to": "key", "source": "main", "reason": "Human-readable issue key" },
        { "from": "fields.summary", "to": "summary", "source": "main", "reason": "Short human-readable title" },
        { "from": "fields.status.name", "to": "status", "source": "main", "reason": "Agent needs state, not status UI metadata" },
        { "from": "fields.description", "to": "description", "source": "main", "transform": "firstLine", "reason": "Concise problem statement" },
        { "from": "fields.assignee.name", "to": "assignee_name", "source": "main", "reason": "Owner name" },
        { "from": "fields.updated", "to": "updated", "source": "main", "reason": "Freshness signal" }
      ]
    }
  ],
  "hiddenEndpoints": [
    { "endpoint": "GET /avatars/{id}", "reason": "UI asset metadata" },
    { "endpoint": "POST /webhooks", "reason": "Operational endpoint outside V1 toolset" }
  ]
}
